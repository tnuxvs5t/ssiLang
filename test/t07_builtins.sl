# Type
print(type(42))
print(type("hi"))
print(type(true))
print(type(null))
print(type([1]))
print(type({a: 1}))
print(type(x -> x))

# Conversions
print(int("123"))
print(int(3.7))
print(float("3.14"))
print(str(42))

# Range
print(range(5))
print(range(2, 7))
print(range(0, 10, 3))
print(range(5, 0, -1))

# Math
print(abs(-5))
print(min(3, 7))
print(max(3, 7))

# Sort
print(sort([3, 1, 4, 1, 5, 9, 2, 6]))
print(sort(["banana", "apple", "cherry"]))

# Len
print(len([1, 2, 3]))
print(len("hello"))
print(len({a: 1, b: 2}))

# String indexing
s = "hello"
print(s[0])
print(s[4])
