# Literals and print
print(42)
print(3.14)
print("hello")
print(true)
print(false)
print(null)

# Arithmetic
print(1 + 2)
print(10 - 3)
print(4 * 5)
print(15 / 4)
print(17 % 5)
print(-7)

# String concat
print("foo" + "bar")
print("n=" + str(42))

# Comparison
print(1 < 2)
print(3 >= 3)
print(1 == 1)
print(1 != 2)

# Logic
print(true and false)
print(true or false)
print(not true)
